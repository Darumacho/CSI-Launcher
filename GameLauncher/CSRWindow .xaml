<Window x:Class="GameLauncher.CSRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ContentRendered="Window_ContentRendered"
        Title="CSI Rogue" Height="680" Width="1024" Background="Black" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="609*"/>
            <ColumnDefinition Width="415*"/>
        </Grid.ColumnDefinitions>
        <Image Stretch="UniformToFill" Source="/images/CSR_Title.png" Margin="-131,-55,-160,-95" Grid.ColumnSpan="2" />
        <!--<MediaElement Source="/images/013_1000.gif" LoadedBehavior="Play" Visibility="Visible" />-->
        <TextBlock Name="VersionText" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="20" FontFamily="/CSILauncher;component/fonts/#Eurocentric"  Foreground="White" Margin="0, 0, 5, 0" Grid.Column="1"/>
        <!--<TextBlock Text="Nouveautés :" FontSize="30" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontStyle="Italic" Background="White" Foreground="Gray" Margin="40,116,756,161"/>-->
        <Button Name="PlayButton" Content="Vérification du contenu..." Click="PlayButton_Click" Height="60" FontSize="24" FontFamily="/CSILauncher;component/fonts/#Eurocentric" Foreground="#DDFFFFFF" VerticalAlignment="Top" HorizontalAlignment="Center" MinWidth="150" Background="#545ba8" Padding="10,1,10,1" Width="460" Margin="0,496,0,0" Grid.ColumnSpan="2"/>
        <Button x:Name="BackToMenu" Content="Retour" Click="Return_Click" Height="50" FontSize="28" FontFamily="/CSILauncher;component/fonts/#Eurocentric" Foreground="#DDFFFFFF" VerticalAlignment="Top" HorizontalAlignment="Left" MinWidth="150" Background="#545ba8" Padding="10,1,10,1" Width="60" Margin="10,574,0,0"/>
        <Border Background="#BB000000" CornerRadius="6" Margin="30,355,30,0" Height="125" VerticalAlignment="Top" Grid.ColumnSpan="2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Nouveautés" FontFamily="Optimus" FontSize="16" Foreground="#AAFFFFFF" Margin="8,5,0,3"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Name="PatchNotesText" FontFamily="Optimus" FontSize="13" Foreground="White" TextWrapping="Wrap" Margin="8,0,8,5"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
