<Window x:Class="GameLauncher.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher"
        mc:Ignorable="d"
        Title="CSI Launcher" Height="680" Width="1024" Background="#545ba8" ResizeMode="NoResize"
        ContentRendered="Window_ContentRendered">
    <Window.Resources>
        <Style x:Key="GameTooltip" TargetType="ToolTip">
            <Setter Property="Background" Value="#EE1a1a2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MaxWidth" Value="240"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="#545ba8" BorderThickness="1" Padding="12,8">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap"
                                       Foreground="White" FontFamily="Optimus" FontSize="13"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition x:Name="SettingsColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Permanent sidebar -->
        <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Background="#CC1a1a2e">
            <StackPanel HorizontalAlignment="Center">
                <Image Source="/images/Team_CSI_logo_transparent.png" Width="50" Margin="0,15,0,10"/>
                <Button Content="⚙" Click="SettingsToggle_Click"
                        Width="32" Height="32" FontSize="16"
                        Background="Transparent" Foreground="White" BorderBrush="Transparent" Padding="0"/>
            </StackPanel>
        </Border>

        <!-- Settings panel -->
        <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Background="#F01a1a2e" ClipToBounds="True">
            <StackPanel Margin="15,15,15,0">
                <TextBlock Text="Paramètres" FontFamily="Eurocentric" FontSize="22" Foreground="White" Margin="0,0,0,20"/>
                <TextBlock Text="Dossier d'installation :" FontFamily="Eurocentric" FontSize="13" Foreground="#AAFFFFFF" Margin="0,0,0,6"/>
                <TextBox x:Name="InstallPathBox" FontSize="11" Padding="6"
                         Background="#22FFFFFF" Foreground="White"
                         BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>
                <Button Content="Parcourir..." Click="BrowseFolder_Click"
                        Margin="0,10,0,0" Height="34" FontFamily="Eurocentric"
                        FontSize="13" Background="#545ba8" Foreground="White" BorderBrush="Transparent"/>
                <Button Content="Enregistrer" Click="SaveSettings_Click"
                        Margin="0,8,0,0" Height="34" FontFamily="Eurocentric"
                        FontSize="13" Background="#3a9e5f" Foreground="White" BorderBrush="Transparent"/>
            </StackPanel>
        </Border>

        <!-- Welcome message -->
        <TextBlock Grid.Row="1" Grid.Column="2"
                   Text="Bienvenue ! Sélectionnez un jeu."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontFamily="Eurocentric" FontSize="18" Foreground="White"/>

        <!-- Game buttons -->
        <Grid Grid.Row="2" Grid.Column="2" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Width="220" Height="195" HorizontalAlignment="Center"
                    Click="ButtonClicked_1" Background="#FFFFFF"
                    ToolTipService.Placement="Top" ToolTipService.InitialShowDelay="300">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource GameTooltip}"
                             Content="{x:Static local:GameConstants.CSIForeverDescription}"/>
                </Button.ToolTip>
                <Image Source="images/CSI_Button.png" Stretch="Fill"/>
            </Button>
            <Button Grid.Column="1" Width="220" Height="195" HorizontalAlignment="Center"
                    Click="ButtonClicked_2" Background="#FF1D1E1E"
                    ToolTipService.Placement="Top" ToolTipService.InitialShowDelay="300">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource GameTooltip}"
                             Content="{x:Static local:GameConstants.CSIIForeverDescription}"/>
                </Button.ToolTip>
                <Image Source="images/CSII_Button.png" Stretch="Fill"/>
            </Button>
            <Button Grid.Column="2" Width="220" Height="195" HorizontalAlignment="Center"
                    Click="ButtonClicked_R" Background="Black"
                    ToolTipService.Placement="Top" ToolTipService.InitialShowDelay="300">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource GameTooltip}"
                             Content="{x:Static local:GameConstants.CSIRogueDescription}"/>
                </Button.ToolTip>
                <Image Source="images/CSR_Button.png" Stretch="Fill"/>
            </Button>
        </Grid>

        <!-- Patch notes -->
        <Border Grid.Row="3" Grid.Column="2" Background="#BB000000" CornerRadius="6" Margin="10,5,10,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Nouveautés" FontFamily="Optimus" FontSize="16" Foreground="#AAFFFFFF" Margin="8,5,0,3"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Name="PatchNotesText" FontFamily="Optimus" FontSize="13" Foreground="White" TextWrapping="Wrap" Margin="8,0,8,5"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
