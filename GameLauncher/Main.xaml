<Window x:Class="GameLauncher.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher"
        mc:Ignorable="d"
        Title="CSI Launcher" Height="760" Width="1280" Background="#545ba8"
        ContentRendered="Window_ContentRendered">
    <Window.Resources>
        <Style x:Key="GameTooltip" TargetType="ToolTip">
            <Setter Property="Background" Value="#EE1a1a2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MaxWidth" Value="240"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="#545ba8" BorderThickness="1" Padding="12,8">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap"
                                       Foreground="White" FontFamily="Optimus" FontSize="13"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#545ba8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#1a1a2e"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#545ba8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#545ba8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Margin="8,0,24,0"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextElement.Foreground="White"/>
                            <Popup Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Slide">
                                <Border Background="#1a1a2e" BorderBrush="#545ba8" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition x:Name="SettingsColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Background -->
        <Image x:Name="BackgroundImage" Source="/images/BackgroundMain.png" Stretch="UniformToFill"
               Grid.RowSpan="4" Grid.ColumnSpan="3"/>

        <!-- Permanent sidebar -->
        <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Background="#CC1a1a2e">
            <DockPanel>
                <TextBlock x:Name="LauncherVersionText" DockPanel.Dock="Bottom" Text="v1.0"
                           FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="18"
                           Foreground="#66FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <Border DockPanel.Dock="Bottom" Height="1" Background="#55FFFFFF" Margin="8,0,8,8"/>
                <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center" Margin="0,0,0,4">
                    <Button Click="WebsiteButton_Click"
                            Width="44" Height="44"
                            Background="Transparent" BorderBrush="Transparent" Padding="2" Margin="0,6,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Visiter CSI World"/>
                        </Button.ToolTip>
                        <Image Source="/images/WebsiteLogo.png" Stretch="Uniform"/>
                    </Button>
                    <Button Click="DiscordButton_Click"
                            Width="44" Height="44" Visibility="Collapsed"
                            Background="Transparent" BorderBrush="Transparent" Padding="2" Margin="0,6,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Rejoindre Discord"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Fill="White"
                                  Data="M20.317 4.37a20.791 20.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a19.269 19.269 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A20.801 20.801 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a20.84 20.84 0 0 0 6.293 3.189.077.077 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.718 13.718 0 0 1-1.96-.93.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c4.114 1.87 8.566 1.87 12.633 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.93 12.93 0 0 1-1.96.93.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 20.76 20.76 0 0 0 6.3-3.189.077.077 0 0 0 .031-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                        </Viewbox>
                    </Button>
                    <Button Click="GithubButton_Click"
                            Width="44" Height="44"
                            Background="Transparent" BorderBrush="Transparent" Padding="2" Margin="0,6,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="GitHub"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Fill="White"
                                  Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
                <!-- Top section: logo (home), game buttons, settings/contact -->
                <StackPanel HorizontalAlignment="Center">
                    <Button Click="SidebarHome_Click" Background="Transparent" BorderBrush="Transparent"
                            Padding="0" Cursor="Hand"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Accueil"/>
                        </Button.ToolTip>
                        <Image Source="/images/Team_CSI_logo_transparent.png" Width="50" Margin="0,15,0,10"/>
                    </Button>
                    <Border Height="1" Background="#55FFFFFF" Margin="8,0,8,6"/>

                    <!-- Home / settings / contact -->
                    <Button Content="⌂" Click="SidebarHome_Click"
                            Width="32" Height="32" FontSize="20"
                            Background="Transparent" Foreground="White" BorderBrush="Transparent" Padding="0" Margin="0,3,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Accueil"/>
                        </Button.ToolTip>
                    </Button>
                    <Button Content="⚙" Click="SettingsToggle_Click"
                            Width="32" Height="32" FontSize="16"
                            Background="Transparent" Foreground="White" BorderBrush="Transparent" Padding="0" Margin="0,10,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Paramètres"/>
                        </Button.ToolTip>
                    </Button>
                    <Button Content="✉" Click="ContactButton_Click"
                            Width="32" Height="32" FontSize="18"
                            Background="Transparent" Foreground="White" BorderBrush="Transparent" Padding="0" Margin="0,10,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Contact"/>
                        </Button.ToolTip>
                    </Button>

                    <Border Height="1" Background="#55FFFFFF" Margin="8,8,8,8"/>

                    <!-- Game navigation buttons -->
                    <Button Click="SidebarCSI_Click" Width="54" Height="42"
                            Background="Transparent" BorderBrush="Transparent" Padding="2" Margin="0,3,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="CSI Forever"/>
                        </Button.ToolTip>
                        <Image Source="images/CSI_Button.png" Stretch="Uniform"/>
                    </Button>
                    <Button Click="SidebarCSII_Click" Width="54" Height="42"
                            Background="Transparent" BorderBrush="Transparent" Padding="2" Margin="0,3,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="CSII Forever"/>
                        </Button.ToolTip>
                        <Image Source="images/CSII_Button.png" Stretch="Uniform"/>
                    </Button>
                    <Button Click="SidebarCSR_Click" Width="54" Height="42"
                            Background="Transparent" BorderBrush="Transparent" Padding="2" Margin="0,3,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="CSI Rogue"/>
                        </Button.ToolTip>
                        <Image Source="images/CSR_Button.png" Stretch="Uniform"/>
                    </Button>
                    <Button Click="SidebarNarval_Click" Width="54" Height="42"
                            Background="Transparent" BorderBrush="Transparent" Padding="2" Margin="0,3,0,0"
                            ToolTipService.Placement="Right" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Narval Souls"/>
                        </Button.ToolTip>
                        <Image Source="images/Narval_Button.png" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Settings panel -->
        <Border x:Name="SettingsPanelBorder" Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Background="#F01a1a2e" ClipToBounds="True" Visibility="Collapsed">
            <StackPanel Margin="15,15,15,0">
                <TextBlock Text="Paramètres" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="22" Foreground="White" Margin="0,0,0,20"/>
                <TextBlock Text="Dossier d'installation :" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Foreground="#AAFFFFFF" Margin="0,0,0,6"/>
                <TextBox x:Name="InstallPathBox" FontSize="11" Padding="6"
                         Background="#22FFFFFF" Foreground="White"
                         BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>
                <Button Content="Parcourir..." Click="BrowseFolder_Click"
                        Margin="0,10,0,0" Height="34" FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                        FontSize="13" Background="#545ba8" Foreground="White" BorderBrush="Transparent"/>
                <CheckBox x:Name="AutoUpdateCheckBox"
                          Content="Mises à jour automatiques"
                          FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                          FontSize="13" Foreground="White" Margin="0,16,0,0"/>
                <TextBlock Text="Fond d'écran :"
                           FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                           FontSize="13" Foreground="#AAFFFFFF" Margin="0,16,0,6"/>
                <ComboBox x:Name="BackgroundComboBox"
                          Style="{StaticResource DarkComboBox}"
                          FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                          FontSize="13" Height="30">
                    <ComboBoxItem Content="Défaut" Tag="BackgroundMain.png"/>
                    <ComboBoxItem Content="Cosmos" Tag="BackgroundSpace.png"/>
                    <ComboBoxItem Content="Pétillant" Tag="BackgroundStars.png"/>
                    <ComboBoxItem Content="Futuriste" Tag="BackgroundCyber.png"/>
                    <ComboBoxItem Content="Singularité" Tag="BackgroundAbstract.png"/>
                </ComboBox>
                <Button Content="Enregistrer paramètres" Click="SaveSettings_Click"
                        Margin="0,16,0,0" Height="34" FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                        FontSize="13" Background="#3a9e5f" Foreground="White" BorderBrush="Transparent"/>
            </StackPanel>
        </Border>

        <!-- Contact panel -->
        <Border x:Name="ContactPanelBorder" Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Background="#F01a1a2e" ClipToBounds="True" Visibility="Collapsed">
            <StackPanel Margin="15,15,15,0">
                <TextBlock Text="Contact" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="22" Foreground="White" Margin="0,0,0,20"/>
                <TextBlock Text="Votre adresse mail * :" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Foreground="#AAFFFFFF" Margin="0,0,0,6"/>
                <TextBox x:Name="ContactEmailBox" FontSize="11" Padding="6"
                         Background="#22FFFFFF" Foreground="White"
                         BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>
                <TextBlock Text="Votre nom :" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Foreground="#AAFFFFFF" Margin="0,10,0,6"/>
                <TextBox x:Name="ContactNameBox" FontSize="11" Padding="6"
                         Background="#22FFFFFF" Foreground="White"
                         BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>
                <TextBlock Text="Sujet :" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Foreground="#AAFFFFFF" Margin="0,10,0,6"/>
                <TextBox x:Name="ContactSubjectBox" FontSize="11" Padding="6"
                         Background="#22FFFFFF" Foreground="White"
                         BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>
                <TextBlock Text="Message :" FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Foreground="#AAFFFFFF" Margin="0,10,0,6"/>
                <TextBox x:Name="ContactMessageBox" FontSize="11" Padding="6" Height="110"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         Background="#22FFFFFF" Foreground="White"
                         BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>
                <Button x:Name="ContactSendButton" Content="Envoyer" Click="SendContact_Click"
                        Margin="0,16,0,0" Height="34" FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                        FontSize="13" Background="#545ba8" Foreground="White" BorderBrush="Transparent"/>
                <TextBlock x:Name="ContactStatusText" FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                           FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- App logo -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"
                CornerRadius="16" BorderBrush="#55FFFFFF" BorderThickness="1"
                Background="#22000000" Padding="18,10">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <Image Source="/images/AppLogo.png" Height="100" Stretch="Uniform"/>
        </Border>

        <!-- Home: launcher patch notes (stays below logo when no game is selected) -->
        <Border x:Name="HomePanel" Grid.Row="2" Grid.RowSpan="2" Grid.Column="2"
                Background="#BB000000" CornerRadius="6" Margin="10,0,10,10"
                VerticalAlignment="Bottom" Height="228">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Nouveautés" FontFamily="Optimus" FontSize="16" Foreground="#AAFFFFFF" Margin="8,5,0,3"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="PatchNotesText" FontFamily="Optimus" FontSize="13" Foreground="White" TextWrapping="Wrap" Margin="8,0,8,5"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Game panels: span all rows so they cover the full content area including the logo -->
        <Grid Grid.Row="0" Grid.RowSpan="4" Grid.Column="2">

            <!-- CSI Forever -->
            <Grid x:Name="CSIPanel" Visibility="Collapsed">
                <Image Stretch="UniformToFill" Source="/images/CSI_Title.png"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,10,10,0">
                    <Button x:Name="CSI_ExportButton" Click="CSI_ExportSave_Click" Width="34" Height="34"
                            Visibility="Collapsed"
                            Background="#AA000000" BorderBrush="Transparent" Padding="0"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,6,0"
                            ToolTipService.Placement="Bottom" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Exporter les sauvegardes"/>
                        </Button.ToolTip>
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Fill="White" Data="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="CSI_ImportButton" Click="CSI_ImportSave_Click" Width="34" Height="34"
                            Visibility="Collapsed"
                            Background="#AA000000" BorderBrush="Transparent" Padding="0"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            ToolTipService.Placement="Bottom" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Importer une sauvegarde"/>
                        </Button.ToolTip>
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Fill="White" Data="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="CSI_UninstallButton" Click="CSI_Uninstall_Click" Width="34" Height="34"
                            Visibility="Collapsed"
                            Background="#AA5c0000" BorderBrush="Transparent" Padding="0"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="10,0,0,0"
                            ToolTipService.Placement="Bottom" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Désinstaller"/>
                        </Button.ToolTip>
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Fill="White" Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
                <Border x:Name="CSI_ItemOfTheDayBox" Background="#BB000000" CornerRadius="6"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="250" MaxHeight="360" Margin="0,54,10,0" Visibility="Collapsed">
                    <DockPanel Margin="8,6,8,6">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,3">
                            <Image x:Name="CSI_ItemOfTheDayIcon" Width="32" Height="32"
                                   DockPanel.Dock="Left" Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   VerticalAlignment="Top"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="CSI_ItemOfTheDayTitle" FontFamily="Optimus" FontSize="13"
                                           Foreground="White" TextWrapping="Wrap"/>
                                <TextBlock x:Name="CSI_ItemOfTheDayCategory" FontFamily="Optimus" FontSize="10"
                                           Foreground="#77FFFFFF" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                        <Rectangle DockPanel.Dock="Top" Fill="#33FFFFFF" Height="1" Margin="0,4,0,5"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CSI_ItemOfTheDayProps"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                <TextBlock x:Name="CSI_VersionText" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                           FontSize="22" FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                           Foreground="White" Margin="0,0,5,5">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.9"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Border Background="#BB000000" CornerRadius="6" Margin="30,0,30,76" Height="130" VerticalAlignment="Bottom">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Nouveautés" FontFamily="Optimus" FontSize="14" Foreground="#AAFFFFFF" Margin="8,4,0,2"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="CSI_PatchNotesText" FontFamily="Optimus" FontSize="12" Foreground="White" TextWrapping="Wrap" Margin="8,0,8,4"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,252">
                    <Button x:Name="CSI_PlayButton" Content="Vérification du contenu..." Click="CSI_PlayButton_Click"
                            Height="56" FontSize="22" FontFamily="/CSILauncher;component/fonts/#Eurocentric"
                            Foreground="#DDFFFFFF" Background="#545ba8" Padding="10,1,10,1" Width="400" BorderBrush="Transparent"/>
                    <Button Click="CSI_FolderButton_Click" Width="56" Height="56" Margin="8,0,0,0"
                            Background="#545ba8" BorderBrush="Transparent"
                            ToolTipService.Placement="Top" ToolTipService.InitialShowDelay="300">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource GameTooltip}" Content="Ouvrir le dossier d'installation"/>
                        </Button.ToolTip>
                        <Viewbox Width="26" Height="26">
                            <Path Fill="White" Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>

