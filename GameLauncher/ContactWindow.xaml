<Window x:Class="GameLauncher.ContactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contact" Height="420" Width="460"
        Background="#1a1a2e" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="24">
        <TextBlock Text="Nous contacter" Foreground="White"
                   FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="22" Margin="0,0,0,20"/>

        <TextBlock Text="Nom :" Foreground="#AAFFFFFF"
                   FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" FontSize="13" Padding="6" Margin="0,0,0,14"
                 Background="#22FFFFFF" Foreground="White"
                 BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>

        <TextBlock Text="Sujet :" Foreground="#AAFFFFFF"
                   FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Margin="0,0,0,6"/>
        <TextBox x:Name="SubjectBox" FontSize="13" Padding="6" Margin="0,0,0,14"
                 Background="#22FFFFFF" Foreground="White"
                 BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>

        <TextBlock Text="Message :" Foreground="#AAFFFFFF"
                   FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13" Margin="0,0,0,6"/>
        <TextBox x:Name="MessageTextBox" FontSize="13" Padding="6" Height="110"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 Background="#22FFFFFF" Foreground="White"
                 BorderBrush="#545ba8" BorderThickness="1" CaretBrush="White"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Annuler" Click="Cancel_Click"
                    Width="110" Height="34" Margin="0,0,10,0"
                    FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13"
                    Background="#44FFFFFF" Foreground="White" BorderBrush="Transparent"/>
            <Button Content="Envoyer" Click="Send_Click"
                    Width="110" Height="34"
                    FontFamily="/CSILauncher;component/fonts/#Eurocentric" FontSize="13"
                    Background="#545ba8" Foreground="White" BorderBrush="Transparent"/>
        </StackPanel>
    </StackPanel>
</Window>
