<Window x:Class="GameLauncher.NarvalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ContentRendered="Window_ContentRendered"
        Title="Narval Souls" Height="680" Width="1024" Background="#0a1628" ResizeMode="NoResize">
    <Grid>
        <Image Stretch="UniformToFill" Source="/images/Narval_Title.png" Margin="0"/>
        <TextBlock Name="VersionText" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="20" FontFamily="/CSILauncher;component/fonts/#Pixel Operator" Foreground="White" Margin="0,0,5,0"/>
        <Button Name="PlayButton" Content="Vérification du contenu..." Click="PlayButton_Click" Height="60" FontSize="28" FontFamily="/CSILauncher;component/fonts/#Pixel Operator" Foreground="#DDFFFFFF" VerticalAlignment="Top" HorizontalAlignment="Center" MinWidth="150" Background="#0d4a6b" Padding="10,1,10,1" Width="460" Margin="0,496,0,0"/>
        <Button x:Name="BackToMenu" Content="Retour" Click="Return_Click" Height="60" FontSize="36" FontFamily="/CSILauncher;component/fonts/#Pixel Operator" Foreground="#DDFFFFFF" VerticalAlignment="Top" HorizontalAlignment="Left" MinWidth="150" Background="#0d4a6b" Padding="10,1,10,1" Width="70" Margin="10,574,0,0"/>
        <Border Background="#BB000000" CornerRadius="6" Margin="30,355,30,0" Height="125" VerticalAlignment="Top">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Nouveautés" FontFamily="/CSILauncher;component/fonts/#Pixel Operator" FontSize="22" Foreground="#AAFFFFFF" Margin="8,5,0,3"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Name="PatchNotesText" FontFamily="/CSILauncher;component/fonts/#Pixel Operator" FontSize="18" Foreground="White" TextWrapping="Wrap" Margin="8,0,8,5"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
